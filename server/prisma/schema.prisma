// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  avatarUrl           String?
  role                String   @default("USER")
  isVerified          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  teams               TeamMember[]
  authTokens          AuthToken[]
  refreshTokens       RefreshToken[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  inviteCode          String   @unique
  inviteCodeExpires   DateTime?
  permissions         Permission[]
  members             TeamMember[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id      String   @id @default(cuid())
  userId  String
  teamId  String
  role    String   @default("MEMBER") // ADMIN, MEMBER
  permissions Json?    @default("{}") // RBAC custom permissions for this user in this team
  user    User     @relation(fields: [userId], references: [id])
  team    Team     @relation(fields: [teamId], references: [id])
  @@unique([userId, teamId])
}

model Chamado {
  id           String    @id @default(cuid())
  situacao     String?
  numero       String?
  dataEmissao  DateTime?
  pedido       String?
  notaFiscal   String?
  vencimento   DateTime?
  valor        Float?    @default(0)
  forma        String?
  razao        String?
  cnpj         String?
  setor        String?
  codEtica     String?   @default("nao")
  requisitante String?
  obs          String?
  deleted      Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@index([cnpj])
  @@index([deleted, createdAt])
}

model ShoppingTicket {
  id            String    @id @default(cuid())
  situacao      String?
  numero        String?
  solicitacao   String?
  pedido        String?
  prazoEntrega  DateTime?
  valor         Float?    @default(0)
  prazoPagto    DateTime?
  razao         String?
  cnpj          String?
  requisitante  String?
  obs           String?
  deleted       Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([cnpj])
  @@index([deleted, createdAt])
}

model FreightTicket {
  id            String    @id @default(cuid())
  situacao      String?
  numero        String?
  solicitacao   String?
  pedido        String?
  prazoEntrega  DateTime?
  valor         Float?    @default(0)
  prazoPagto    DateTime?
  razao         String?
  cnpj          String?
  requisitante  String?
  obs           String?
  deleted       Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([cnpj])
  @@index([deleted, createdAt])
}

model Procedimento {
  id          String   @id @default(cuid())
  titulo      String
  descricao   String?
  categoria   String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lixeira {
  id          String   @id @default(cuid())
  originalId  String   
  tipo        String   
  conteudo    String   
  deletedAt   DateTime @default(now())
}

model AuthToken {
  id          String   @id @default(cuid())
  code        String   @unique
  tokenType   String   // "REGISTRATION" ou "PASSWORD_RESET"
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime
  deletedAt   DateTime?
  deleted     Boolean  @default(false)

  @@index([userId])
}

model Ponto {
  id           String    @id @default(cuid())
  data         String?
  entrada      String?
  saida        String?
  resultado    String?
  saldoMinutos Int?      @default(0)
  type         String    @default("ponto_record")
  deleted      Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([deleted, createdAt])
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique 
  teams       Team[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deleted     Boolean  @default(false)

  @@index([name])
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}
